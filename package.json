{
  "name": "sound-desk-sim",
  "private": true,
  "version": "0.1.0",
  "description": "A live-sound mixing desk that runs in your browser — a full channel-strip signal chain and a 3D stage you can hear in real time. Vue 3 + Web Audio API, installable as a PWA.",
  "license": "MIT",
  "homepage": "https://lucky-c.github.io/sound-desk-sim/",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucky-c/sound-desk-sim.git"
  },
  "bugs": {
    "url": "https://github.com/lucky-c/sound-desk-sim/issues"
  },
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "typecheck": "vue-tsc --noEmit",
    "test": "bun test tests/",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^3.0.3",
    "three": "^0.185.1",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/bun": "^1.3.14",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.1",
    "vue-tsc": "^3.0.1"
  }
}
